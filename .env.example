# ==============================================================================
# Basket-Bud — Environment Variables Example
# ==============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit your .env file to version control.
#
# This file documents every environment variable required to run the Basket-Bud
# backend (Node.js/Express) and its integrations with PostgreSQL and Claude Vision.
# ==============================================================================


# ------------------------------------------------------------------------------
# SERVER CONFIGURATION
# ------------------------------------------------------------------------------

# The port the Express backend will listen on
# Default: 3001 (React Native frontend expects this by default)
PORT=3001

# Node environment — set to 'production' on your home server
# Options: development | test | production
NODE_ENV=development

# The base URL of the backend API, used internally and for constructing links
# On your home server this will be your local IP or hostname
API_BASE_URL=http://192.168.1.100:3001

# Origin the frontend is served from — used to lock CORS in production.
# Must match the URL the React Native web build or Expo is served from.
# In development this is optional (all origins allowed).
# In production (NODE_ENV=production) this MUST be set or all cross-origin requests will be blocked.
FRONTEND_URL=http://192.168.1.100:19006


# ------------------------------------------------------------------------------
# DATABASE — PostgreSQL
# ------------------------------------------------------------------------------

# PostgreSQL connection details for the Basket-Bud database
# Use a dedicated database user with only the permissions the app needs
# (SELECT, INSERT, UPDATE, DELETE on basket_bud tables — not a superuser)

DB_HOST=localhost
DB_PORT=5432
DB_NAME=basket_bud
DB_USER=basket_bud_user
DB_PASSWORD=your_strong_database_password_here

# Full connection string — alternative to the individual variables above.
# Some libraries (e.g., pg, knex) can use this directly.
# Construct it as: postgresql://DB_USER:DB_PASSWORD@DB_HOST:DB_PORT/DB_NAME
DATABASE_URL=postgresql://basket_bud_user:your_strong_database_password_here@localhost:5432/basket_bud

# Maximum number of clients in the PostgreSQL connection pool
DB_POOL_MAX=10

# SSL for database connections (set to true if using SSL on your home server setup)
DB_SSL=false


# ------------------------------------------------------------------------------
# AUTHENTICATION — JWT
# ------------------------------------------------------------------------------

# Secret key used to sign and verify JSON Web Tokens for API authentication.
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Minimum recommended length: 64 characters
JWT_SECRET=replace_this_with_a_long_random_secret_string_at_least_64_characters

# How long access tokens remain valid before expiry
# Uses ms/zeit format: e.g., 7d, 24h, 60m
JWT_EXPIRES_IN=7d

# How long refresh tokens remain valid
JWT_REFRESH_EXPIRES_IN=30d


# ------------------------------------------------------------------------------
# OCR — Claude Vision (REQUIRED)
# ------------------------------------------------------------------------------

# Anthropic API key used for receipt scanning via Claude Vision.
# REQUIRED — the app cannot scan receipts without this key.
# Obtain your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here


# ------------------------------------------------------------------------------
# FILE UPLOADS — Receipt Images
# ------------------------------------------------------------------------------

# Directory where uploaded receipt images are temporarily stored during OCR processing.
# Files are deleted after successful extraction.
# Ensure this path is NOT web-accessible.
UPLOAD_DIR=./storage/uploads

# Maximum allowed size for uploaded receipt images (in bytes).
# Default: 10MB — sufficient for high-resolution phone camera images.
MAX_UPLOAD_SIZE_BYTES=10485760

# Allowed MIME types for receipt image uploads (comma-separated).
# Basket-Bud accepts JPEG and PNG from the React Native camera.
ALLOWED_UPLOAD_MIME_TYPES=image/jpeg,image/png

# How long (in milliseconds) to retain uploaded images after OCR processing
# before the cleanup job deletes them. Set to 0 to delete immediately.
UPLOAD_RETENTION_MS=0


# ------------------------------------------------------------------------------
# PRICE NORMALISATION
# ------------------------------------------------------------------------------

# Default currency code used when displaying and comparing prices across shops.
# Basket-Bud does not use currency conversion — all receipts are assumed to be
# in this currency.
DEFAULT_CURRENCY=GBP

# The weight unit used as the base for per-weight price normalisation.
# All weight-based prices are normalised to this unit for comparison.
# Options: kg | lb | g | oz
# Recommended: kg (standard for UK supermarkets)
PRICE_NORMALISATION_WEIGHT_UNIT=kg

# The default quantity unit used for per-unit price normalisation.
PRICE_NORMALISATION_UNIT_LABEL=each


# ------------------------------------------------------------------------------
# ANALYTICS — Spending Dashboard
# ------------------------------------------------------------------------------

# Default number of days of historical data to show in the analytics dashboard
# on first load. Users can adjust this in-app.
ANALYTICS_DEFAULT_DATE_RANGE_DAYS=90

# Maximum number of shops to display in side-by-side comparison charts.
# Keeps Recharts chart layouts manageable.
ANALYTICS_MAX_SHOPS_IN_COMPARISON=6


# ------------------------------------------------------------------------------
# LOGGING
# ------------------------------------------------------------------------------

# Log level for the backend application.
# Options: error | warn | info | debug
# Use 'debug' during development, 'info' or 'warn' in production.
LOG_LEVEL=info

# Log output format.
# Options: pretty (human-readable, good for dev) | json (structured, good for prod)
LOG_FORMAT=pretty

# Path to log file. Leave empty to log to stdout only (recommended for home server
# setups where you manage logs at the system level via journald or similar).
LOG_FILE_PATH=


# ------------------------------------------------------------------------------
# CORS
# ------------------------------------------------------------------------------

# Allowed origins for Cross-Origin Resource Sharing.
# In development, React Native Metro bundler may make requests from localhost.
# In production (self-hosted), lock this down to your local network or leave
# empty to restrict all cross-origin requests.
# Comma-separated list of allowed origins.
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://192.168.1.100:8081


# ------------------------------------------------------------------------------
# RATE LIMITING
# ------------------------------------------------------------------------------

# Enable API rate limiting middleware (express-rate-limit).
# Strongly recommended if the API is accessible beyond localhost.
RATE_LIMIT_ENABLED=true

# Time window for rate limiting in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Maximum number of requests per IP per window for general API routes.
RATE_LIMIT_MAX_REQUESTS=100

# Stricter limit for the OCR upload endpoint, which is computationally expensive.
RATE_LIMIT_OCR_MAX_REQUESTS=10


# ------------------------------------------------------------------------------
# HOME SERVER — Self-Hosting
# ------------------------------------------------------------------------------

# Set to true to enable a basic health check endpoint at GET /health
# Useful for monitoring tools (e.g., Uptime Kuma) running on your home server.
HEALTH_CHECK_ENABLED=true

# Optional: path to a Unix socket file if you're running the Express server
# behind Nginx on the same machine. Leave empty to use TCP (PORT above).
UNIX_SOCKET_PATH=